# Copy to ~/.config/r1-hermes/r1-hermes.env and chmod 600. The systemd
# unit reads this file with EnvironmentFile= and keeps token literals out of
# the unit and drop-ins.
# Generate the token locally; do not paste real tokens into unit files,
# shell history, GitHub comments, or support tickets.
R1_HERMES_GATEWAY_TOKEN=replace-with-generated-token

# Keep localhost unless the Rabbit R1 reaches this host through a reviewed
# private network path such as Tailscale. Wildcard binds fail closed unless
# R1_HERMES_ALLOW_PUBLIC_BIND=1 is explicitly set; prefer a concrete IP.
R1_HERMES_HOST=127.0.0.1
R1_HERMES_PORT=18789
# R1_HERMES_ALLOW_PUBLIC_BIND=1

# For proxyless public operation, do not use cleartext ws://. Bind to the reviewed
# public address with native TLS enabled and advertise wss:// in the QR payload.
# The certificate must cover the public hostname/IP Rabbit R1 will connect to.
# R1_HERMES_TLS_CERT_FILE=/etc/letsencrypt/live/r1-hermes.example.com/fullchain.pem
# R1_HERMES_TLS_KEY_FILE=/etc/letsencrypt/live/r1-hermes.example.com/privkey.pem

# Keep Hermes tool access narrow until the network boundary is reviewed.
# High-impact toolsets such as terminal, file/filesystem, browser/desktop
# automation, smart-home, and vehicle controls fail closed unless the separate
# explicit approval flag below is enabled after a deployment review.
R1_HERMES_TOOLSETS=safe
# Doctor compares the effective R1 toolsets with this reviewed Slack-equivalent
# bundle. Keep the default unless the Slack deployment is intentionally different.
R1_HERMES_SLACK_EQUIVALENT_TOOLSETS=safe,web,terminal,file
# R1_HERMES_ALLOW_HIGH_IMPACT_TOOLSETS=1

# R1 chat runs time out deterministically at the gateway. The older
# R1_HERMES_TIMEOUT name is still accepted; prefer the explicit name below for
# new service files. Heartbeats are generic running events and must not contain
# prompts, tool stderr, or token material.
R1_HERMES_CHAT_RUN_TIMEOUT_SECONDS=180
R1_HERMES_CHAT_HEARTBEAT_INTERVAL_SECONDS=15
R1_HERMES_TIMEOUT=180

# Keep process caps small for a single Rabbit R1. Increase the global cap only
# after sizing the host for concurrent Hermes subprocesses.
R1_HERMES_GLOBAL_CONCURRENCY=2
R1_HERMES_PER_DEVICE_CONCURRENCY=1

# The packaged user service writes r1-hermes state under the systemd user state
# directory and the readiness file under the systemd user runtime directory. It
# also allows Hermes Agent to update its own ~/.hermes config/session/log state.
# If your Hermes home lives elsewhere, update BindPaths in a unit drop-in;
# do not loosen the sandbox to all of $HOME.

# Pre-authentication WebSocket limits. Keep these conservative; they are not
# a substitute for Tailscale, firewall rules, mTLS, or IP allowlisting.
R1_HERMES_UNAUTHENTICATED_CONNECTION_LIMIT=8
R1_HERMES_UNAUTHENTICATED_ATTEMPT_LIMIT=8
R1_HERMES_UNAUTHENTICATED_ATTEMPT_WINDOW_SECONDS=60
R1_HERMES_UNAUTHENTICATED_COOLDOWN_SECONDS=60
R1_HERMES_UNAUTHENTICATED_TIMEOUT_SECONDS=30

# /healthz is local-only and returns only {"ok": true} by default. Enable these
# only for a reviewed private monitoring path or local diagnostics.
# R1_HERMES_ALLOW_REMOTE_HEALTH=1
# R1_HERMES_HEALTH_DIAGNOSTICS=1
