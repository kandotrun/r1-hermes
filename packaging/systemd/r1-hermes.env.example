# Copy to ~/.config/r1-hermes/r1-hermes.env and chmod 600.
# Generate the token locally; do not paste real tokens into unit files,
# shell history, GitHub comments, or support tickets.
R1_HERMES_GATEWAY_TOKEN=replace-with-generated-token

# Keep localhost unless the Rabbit R1 reaches this host through a reviewed
# private network path such as Tailscale. Avoid wildcard binds.
R1_HERMES_HOST=127.0.0.1
R1_HERMES_PORT=18789

# Keep Hermes tool access narrow until the network boundary is reviewed.
R1_HERMES_TOOLSETS=safe
R1_HERMES_TIMEOUT=180

# Keep process caps small for a single Rabbit R1. Increase the global cap only
# after sizing the host for concurrent Hermes subprocesses.
R1_HERMES_GLOBAL_CONCURRENCY=2
R1_HERMES_PER_DEVICE_CONCURRENCY=1

# Pre-authentication WebSocket limits. Keep these conservative; they are not
# a substitute for Tailscale, firewall rules, mTLS, or IP allowlisting.
R1_HERMES_UNAUTHENTICATED_CONNECTION_LIMIT=8
R1_HERMES_UNAUTHENTICATED_ATTEMPT_LIMIT=8
R1_HERMES_UNAUTHENTICATED_ATTEMPT_WINDOW_SECONDS=60
R1_HERMES_UNAUTHENTICATED_COOLDOWN_SECONDS=60
R1_HERMES_UNAUTHENTICATED_TIMEOUT_SECONDS=30
