# Copy to ~/.config/r1-hermes/r1-hermes.env and chmod 600.
# Generate the token locally; do not paste real tokens into unit files,
# shell history, GitHub comments, or support tickets.
R1_HERMES_GATEWAY_TOKEN=replace-with-generated-token

# Keep localhost unless the Rabbit R1 reaches this host through a reviewed
# private network path such as Tailscale. Avoid wildcard binds.
R1_HERMES_HOST=127.0.0.1
R1_HERMES_PORT=18789

# Keep Hermes tool access narrow until the network boundary is reviewed.
R1_HERMES_TOOLSETS=safe
R1_HERMES_TIMEOUT=180
