include README.md
include LICENSE
include SECURITY.md
include pyproject.toml
graft src
graft docs
graft packaging/systemd
recursive-include src/r1_hermes/systemd *
prune .github
prune .r1-hermes
prune .serena
prune .symphony
prune .venv
prune build
prune dist
prune tests
global-exclude __pycache__
global-exclude *.py[cod]
global-exclude .env
global-exclude .env.*
global-exclude *.log
global-exclude *.ready
global-exclude r1-hermes-secret*.png
global-exclude devices.json
global-exclude device-token-hmac.key
